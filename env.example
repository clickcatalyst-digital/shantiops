# Leave TURSO_URL blank to use a local SQLite file (./shanti-ops-local.db) for dev.
# Set both to point at a Turso database for production / to share data across deployments.
TURSO_URL=
TURSO_AUTH_TOKEN=

# JWT signing secret — set a long random string in production
SESSION_SECRET=change-this-in-production

# Branding shown in the nav bar / login screen / <title>
BRAND_PREFIX=SB
BRAND_NAME=Boilers

PORT=3000

{
  "manifest_version": 3,
  "name": "Shanti Ops Browser Control",
  "version": "1.0.0",
  "description": "Enforces the organization's website access policy via the local Shanti agent.",
  "permissions": ["declarativeNetRequest", "alarms"],
  "host_permissions": ["http://127.0.0.1:47113/*"],
  "background": { "service_worker": "background.js" },
  "web_accessible_resources": [
    { "resources": ["blocked.html"], "matches": ["<all_urls>"] }
  ]
}
